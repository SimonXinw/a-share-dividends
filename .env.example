# ============================================================================
# Supabase 数据库连接（必填）
# 在 Supabase 控制台 → Project Settings → Database → Connection string 获取
# 可保留数据库连接串（用于手动排障或其它工具），主应用已走 Supabase HTTPS API
# 例：postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
# ============================================================================
DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Supabase 项目 URL 和 API Key（后端建议使用 SERVICE_ROLE，至少配置一个 key）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# 同步任务的并发数（同时拉多少只股票数据）
SYNC_CONCURRENCY=5
SYNC_REQUEST_TIMEOUT=15

# 跨域，多个用逗号分隔。* 表示允许所有源
CORS_ORIGINS=*
