# ============================================================================
# Supabase 数据库连接（必填）
# 在 Supabase 控制台 → Project Settings → Database → Connection string 获取
# 推荐使用 "Session" 模式或 "Transaction" 模式的连接串（asyncpg 都兼容）
# 例：postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# ============================================================================
DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres

# Supabase 项目 URL 和匿名 KEY（如果未来要使用 Supabase REST/Auth 可以填，目前可留空）
SUPABASE_URL=
SUPABASE_ANON_KEY=

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# 同步任务的并发数（同时拉多少只股票数据）
SYNC_CONCURRENCY=5
SYNC_REQUEST_TIMEOUT=15

# 跨域，多个用逗号分隔。* 表示允许所有源
CORS_ORIGINS=*
